APP_PORT=3000
APP_DATA_DIR=./data-prod
APP_LOG_DIR=./logs-prod
TZ=Asia/Shanghai

# Change these before first production start.
POSTGRES_PASSWORD=change-this-database-password
SESSION_SECRET=change-this-session-secret-with-32-plus-random-chars
MARKETPLACE_CREDENTIAL_SECRET=change-this-marketplace-credential-secret-with-32-plus-random-chars

# Add any frontend callback domains you explicitly allow users to redirect to.
TRUSTED_REDIRECT_DOMAINS=hermestoken.top
